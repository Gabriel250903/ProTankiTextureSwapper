<UserControl
    x:Class="TextureSwapper.Views.AdminOverlayControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:TextureSwapper.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TextureSwapper.ViewModels"
    d:DataContext="{d:DesignInstance vm:MainViewModel,
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Grid Background="#E6080808">
        <Border
            x:Name="LoginPanel"
            Width="380"
            Height="260"
            Padding="28"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#FF1E1E1E"
            BorderBrush="{DynamicResource SystemAccentColorBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AdminVM.IsAuthenticated}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="30"
                    Opacity="0.8"
                    ShadowDepth="0"
                    Color="Black" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <ui:TextBlock
                        HorizontalAlignment="Center"
                        FontTypography="Subtitle"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Admin Authentication" />
                    <ui:TextBlock
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        FontTypography="Caption"
                        Foreground="#FFA0A0A0"
                        Text="Enter password to access Admin Control" />
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <ui:PasswordBox
                        x:Name="AdminPasswordBox"
                        Margin="0,0,0,12"
                        KeyDown="AdminPasswordBox_KeyDown"
                        PasswordChanged="AdminPasswordBox_PasswordChanged"
                        PlaceholderText="Password" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:Button
                        Grid.Column="0"
                        Margin="0,0,6,0"
                        HorizontalAlignment="Stretch"
                        Click="OnCancelAdminLogin"
                        Content="Cancel" />
                    <ui:Button
                        Grid.Column="1"
                        Margin="6,0,0,0"
                        HorizontalAlignment="Stretch"
                        Appearance="Primary"
                        Command="{Binding AdminVM.LoginCommand}"
                        Content="Login" />
                </Grid>
            </Grid>
        </Border>

        <Border
            x:Name="DashboardPanel"
            Margin="40"
            Padding="28"
            Background="#FF1A1A1A"
            BorderBrush="#FF3A3A3A"
            BorderThickness="1"
            CornerRadius="16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AdminVM.IsAuthenticated}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="40"
                    Opacity="0.9"
                    ShadowDepth="0"
                    Color="Black" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border
                            Width="4"
                            Height="38"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SystemAccentColorBrush}"
                            CornerRadius="2" />
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock
                                FontTypography="Title"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="Admin Dashboard" />
                            <ui:TextBlock
                                Margin="0,2,0,0"
                                FontTypography="Body"
                                Foreground="#FFA0A0A0"
                                Text="Reassign paint folders (ItemName) and save changes back to skins_paints.json" />
                        </StackPanel>
                    </StackPanel>
                    <ui:Button
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Click="OnCloseAdminDashboard"
                        Content="Close"
                        Icon="{ui:SymbolIcon Dismiss24}" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Grid.Column="0"
                        Margin="0,0,16,0"
                        VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBox
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            Background="#FF282828"
                            BorderBrush="#FF444444"
                            ClearButtonEnabled="True"
                            Icon="{ui:SymbolIcon Search24}"
                            PlaceholderText="Search paints by name or folder..."
                            Text="{Binding AdminVM.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <ComboBox
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Background="#FF282828"
                            BorderBrush="#FF444444"
                            ItemsSource="{Binding AdminVM.FilterCategories}"
                            SelectedItem="{Binding AdminVM.SelectedFilterCategory, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                Background="#FF282828"
                                BorderBrush="#FF444444"
                                PlaceholderText="New category..."
                                Text="{Binding AdminVM.NewCategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Appearance="Secondary"
                                Command="{Binding AdminVM.AddCategoryCommand}"
                                Content="Add"
                                Icon="{ui:SymbolIcon Add24}" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                Background="#FF282828"
                                BorderBrush="#FF444444"
                                ItemsSource="{Binding AdminVM.ExistingItemNames}"
                                SelectedItem="{Binding AdminVM.SelectedCategoryToRemove, Mode=TwoWay}" />
                            <ui:Button
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Appearance="Danger"
                                Command="{Binding AdminVM.RemoveCategoryCommand}"
                                Content="Del"
                                Icon="{ui:SymbolIcon Delete24}" />
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                Background="#FF282828"
                                BorderBrush="#FF444444"
                                ItemsSource="{Binding AdminVM.ExistingItemNames}"
                                SelectedItem="{Binding AdminVM.SelectedCategoryToRename, Mode=TwoWay}" />
                            <ui:TextBox
                                Grid.Column="1"
                                Margin="0,0,8,0"
                                Background="#FF282828"
                                BorderBrush="#FF444444"
                                PlaceholderText="Rename to..."
                                Text="{Binding AdminVM.RenameCategoryNewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Appearance="Secondary"
                                Command="{Binding AdminVM.RenameCategoryCommand}"
                                Content="Ren"
                                Icon="{ui:SymbolIcon Edit24}" />
                        </Grid>
                    </Grid>
                </Grid>

                <ListView
                    Grid.Row="2"
                    Margin="0,0,0,16"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding AdminVM.FilteredPaints}"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="12,10"
                                Background="#FF242424"
                                BorderBrush="#FF383838"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="260" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column="0"
                                        Width="44"
                                        Height="44"
                                        Background="#FF111111"
                                        ClipToBounds="True"
                                        CornerRadius="6">
                                        <Image Source="{Binding FullPreviewPath}" Stretch="UniformToFill" />
                                    </Border>

                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center">
                                        <ui:TextBlock
                                            FontSize="14"
                                            FontTypography="BodyStrong"
                                            Foreground="White"
                                            Text="{Binding Name}" />
                                        <ui:TextBlock
                                            Margin="0,2,0,0"
                                            FontTypography="Caption"
                                            Foreground="#FFA0A0A0"
                                            Text="{Binding SourceFolder, StringFormat='Folder: {0}'}" />
                                    </StackPanel>

                                    <ComboBox
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        IsEditable="False"
                                        ItemsSource="{Binding DataContext.AdminVM.ExistingItemNames, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        SelectedItem="{Binding ItemName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Foreground="#FFA0A0A0"
                        Text="{Binding AdminVM.FilteredPaints.Count, StringFormat='Showing {0} paints'}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button
                            Margin="0,0,12,0"
                            Click="OnCloseAdminDashboard"
                            Content="Cancel" />
                        <ui:Button
                            Appearance="Success"
                            Command="{Binding AdminVM.SaveChangesCommand}"
                            Content="Save Changes"
                            FontWeight="Bold" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
