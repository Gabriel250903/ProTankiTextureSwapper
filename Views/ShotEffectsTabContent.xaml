<UserControl
    x:Class="TextureSwapper.Views.ShotEffectsTabContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:TextureSwapper.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <helpers:BindingProxy x:Key="DataContextProxy" Data="{Binding}" />
    </UserControl.Resources>

    <Grid Margin="10,0,10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,15"
            Padding="15"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <WrapPanel HorizontalAlignment="Stretch" Orientation="Horizontal">
                <StackPanel Margin="0,0,200,10" VerticalAlignment="Center">
                    <ui:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="Turret Shot Effects" />
                    <ui:TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Select a turret and choose a custom shot effect."
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel
                    Margin="0,0,0,10"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="Select Turret:" />
                    <ComboBox
                        Width="180"
                        ItemsSource="{Binding ShotEffectTurrets}"
                        SelectedItem="{Binding SelectedShotEffectTurret}" />
                </StackPanel>
            </WrapPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredShotEffects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="220"
                            Margin="8"
                            ClipToBounds="True"
                            CornerRadius="12"
                            Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding
                                    Command="{Binding Data.ToggleShotEffectSelectionCommand, Source={StaticResource DataContextProxy}}"
                                    CommandParameter="{Binding}"
                                    MouseAction="LeftClick" />
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Grid.Row="0"
                                    ClipToBounds="True"
                                    CornerRadius="12,12,0,0">
                                    <Image
                                        Width="150"
                                        Height="150"
                                        Opacity="0.9"
                                        Source="{Binding FullPreviewPath, Converter={StaticResource ImageThumbnailConverter}, IsAsync=True, TargetNullValue={x:Null}}"
                                        Stretch="Uniform" />
                                </Border>

                                <Grid Grid.Row="1" Margin="12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <ui:TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{Binding Name}" />
                                        <ui:TextBlock
                                            Margin="0,2,0,0"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Turret}" />
                                    </StackPanel>

                                    <ui:SymbolIcon
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Filled="True"
                                        Foreground="{DynamicResource SystemAccentColorBrush}"
                                        Symbol="CheckmarkCircle24"
                                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border
            Grid.Row="2"
            Margin="0,15,0,0"
            Padding="15"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ui:InfoBar
                    Title="Turret Asset Requirement"
                    Grid.Row="0"
                    Margin="0,0,0,12"
                    IsClosable="False"
                    IsOpen="True"
                    Message="Applying custom shot effects requires the turret assets to be currently cached by the game loader. Please equip and play with this turret in-game at least once before swapping."
                    Severity="Warning" />

                <ui:Button
                    Grid.Row="1"
                    HorizontalAlignment="Right"
                    Appearance="Success"
                    Command="{Binding SwapShotEffectCommand}"
                    Content="APPLY SHOT EFFECT"
                    FontWeight="Bold"
                    Icon="{ui:SymbolIcon Flash24}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
