<ui:FluentWindow x:Class="TextureSwapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TextureSwapper"
        xmlns:vm="clr-namespace:TextureSwapper.ViewModels"
        xmlns:helpers="clr-namespace:TextureSwapper.Helpers"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="ProTanki Texture Swapper" 
        Height="700" Width="750"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        d:DataContext="{d:DesignInstance vm:MainViewModel, IsDesignTimeCreatable=False}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="ProTanki Texture Swapper"
            Grid.Row="0">
            <ui:TitleBar.TrailingContent>
                <ui:Button x:Name="btnThemeToggle"
                           Margin="0,0,10,0"
                           Padding="8"
                           Appearance="Transparent"
                           Icon="{ui:SymbolIcon WeatherMoon24}"
                           Click="BtnThemeToggle_Click"
                           ToolTip="Toggle Light/Dark Theme" />
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <ui:TextBlock Text="Texture Swapper" FontTypography="Title" />
            </StackPanel>

            <GroupBox Grid.Row="1" Header="ProTanki Cache Path" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="txtCachePath" 
                                Text="{Binding CachePath, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Detecting cache path..." 
                                Margin="0,0,5,0" />
                    <ui:Button Grid.Column="1" 
                               Content="Browse" 
                               Icon="{ui:SymbolIcon Folder24}"
                               Command="{Binding BrowseCommand}" />
                </Grid>
            </GroupBox>

            <Grid Grid.Row="2" Margin="0,0,0,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="150"/>
                    <ColumnDefinition Width="2*" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <ListBox Grid.Row="0" Grid.ColumnSpan="2" 
                         ItemsSource="{Binding Categories}" 
                         SelectedItem="{Binding SelectedCategory}"
                         Margin="0,0,0,15">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Margin" Value="5,0"/>
                            <Setter Property="Padding" Value="15,5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="RootBorder" 
                                                Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="1" 
                                                CornerRadius="4" 
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SystemAccentColorSecondaryBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <GroupBox Grid.Row="1" Header="{Binding SelectedCategory, StringFormat='Select {0}'}" Margin="0,0,10,0">
                    <ui:ListView x:Name="lstItemNames" 
                                 ItemsSource="{Binding ItemNames}"
                                 SelectedItem="{Binding SelectedItemName}" />
                </GroupBox>

                <GroupBox Grid.Row="1" Grid.Column="1" Header="Select Skin">
                    <ui:ListView x:Name="lstSkins" 
                                 ItemsSource="{Binding FilteredSkins}"
                                 SelectedItem="{Binding SelectedSkin}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ui:ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel ItemWidth="150" />
                            </ItemsPanelTemplate>
                        </ui:ListView.ItemsPanel>
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <Border CornerRadius="8" ClipToBounds="True" BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                        <Grid>
                                            <Image Source="{Binding FullPreviewPath}" 
                                                   Height="90" 
                                                   Stretch="UniformToFill" />
                                            <CheckBox IsChecked="{Binding IsSelected}" 
                                                      HorizontalAlignment="Right" 
                                                      VerticalAlignment="Top" 
                                                      Margin="5"/>
                                        </Grid>
                                    </Border>
                                    <ui:TextBlock Text="{Binding Name}" 
                                                  HorizontalAlignment="Center" 
                                                  Margin="0,5,0,0" 
                                                  TextWrapping="Wrap"
                                                  FontTypography="Caption" />
                                </StackPanel>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>
                </GroupBox>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10">
                <ui:Button x:Name="btnSelectAll" 
                           Content="Change all available textures" 
                           Appearance="Secondary"
                           Padding="20,10"
                           Margin="0,0,10,0"
                           Icon="{ui:SymbolIcon CheckmarkCircle24}"
                           Command="{Binding SelectAllAvailableCommand}" />

                <ui:Button x:Name="btnSwap" 
                           Content="Apply Skin" 
                           Appearance="Primary"
                           Padding="25,10"
                           Margin="0,0,10,0"
                           Icon="{ui:SymbolIcon Flash24}"
                           Command="{Binding SwapCommand}" />

                <ui:Button x:Name="btnRestore" 
                           Content="Restore Original" 
                           Appearance="Secondary"
                           Padding="25,10"
                           Margin="0,0,10,0"
                           Icon="{ui:SymbolIcon ArrowUndo24}"
                           Command="{Binding RestoreCommand}" />

                <ui:Button x:Name="btnClearCache" 
                           Content="Clear Cache" 
                           Appearance="Secondary"
                           Padding="25,10"
                           Icon="{ui:SymbolIcon Delete24}"
                           Command="{Binding ClearCacheCommand}" />
            </StackPanel>
        </Grid>
<!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="2" Background="#88000000" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="60" Height="60" />
                <ui:TextBlock Text="{Binding UpdateStatus}" Margin="0,15,0,0" HorizontalAlignment="Center" Foreground="White" FontTypography="BodyStrong" />
                <ui:TextBlock Text="Please wait..." Visibility="{Binding UpdateStatus, Converter={StaticResource StringToVisibilityConverter}}" Margin="0,5,0,0" HorizontalAlignment="Center" Foreground="White" FontTypography="Caption" />
            </StackPanel>
        </Grid>

        <ui:InfoBar x:Name="ToastInfoBar"
                    Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,20,0"
                    Panel.ZIndex="1000"
                    IsClosable="True"
                    IsOpen="False"
                    MaxWidth="350" />
    </Grid>
</ui:FluentWindow>
