<ui:FluentWindow
    x:Class="TextureSwapper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:TextureSwapper.Helpers"
    xmlns:local="clr-namespace:TextureSwapper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TextureSwapper.ViewModels"
    Title="ProTanki Texture Swapper"
    Width="1100"
    Height="780"
    d:DataContext="{d:DesignInstance vm:MainViewModel,
                                     IsDesignTimeCreatable=False}"
    Background="#0F0F0F"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <Style x:Key="StandardButtonStyle" TargetType="ui:Button">
            <Setter Property="Background" Value="#15FFFFFF" />
            <Setter Property="BorderBrush" Value="#20FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="15,8" />
        </Style>

        <Style x:Key="CategoryButtonStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="Root"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#10FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="PROTANKI TEXTURE SWAPPER"
            Height="46"
            VerticalAlignment="Center"
            FontWeight="Bold">
            <ui:TitleBar.Icon>
                <ui:ImageIcon
                    Width="40"
                    Margin="0,-10,0,-7"
                    Source="pack://application:,,,/Textures/logo.png" />
            </ui:TitleBar.Icon>

            <ui:TitleBar.TrailingContent>
                <ui:Button
                    x:Name="btnOpenSettings"
                    Margin="0,0,10,0"
                    Padding="8"
                    Appearance="Transparent"
                    Command="{Binding OpenSettingsCommand}"
                    Icon="{ui:SymbolIcon Settings24}"
                    ToolTip="Settings" />
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <TabControl
            Grid.Row="1"
            Margin="30,0,30,30"
            Background="Transparent"
            BorderThickness="0">
            <TabItem Padding="20,10" Header="SKINS">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,25">
                        <ui:TextBlock
                            FontSize="32"
                            FontTypography="Title"
                            FontWeight="Bold"
                            Text="Texture Swapper" />
                    </StackPanel>

                    <ListBox
                        Grid.Row="1"
                        Margin="0,0,0,20"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource CategoryButtonStyle}"
                        ItemsSource="{Binding Categories}"
                        SelectedItem="{Binding SelectedCategory}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Background="#0AFFFFFF"
                            BorderBrush="#1AFFFFFF"
                            BorderThickness="1,1,0,1"
                            CornerRadius="12,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Margin="15,15,15,10"
                                    FontTypography="Caption"
                                    FontWeight="SemiBold"
                                    Opacity="0.5"
                                    Text="MODELS" />
                                <ui:ListView
                                    Grid.Row="1"
                                    Padding="5,0,5,10"
                                    ItemsSource="{Binding ItemNames}"
                                    SelectedItem="{Binding SelectedItemName}" />
                            </Grid>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Background="#0FFFFFFF"
                            BorderBrush="#1AFFFFFF"
                            BorderThickness="0,1,1,1"
                            CornerRadius="0,12,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="20,15,20,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontTypography="Caption"
                                        FontWeight="SemiBold"
                                        Opacity="0.5"
                                        Text="AVAILABLE SKINS" />

                                    <ui:TextBox
                                        Grid.Column="2"
                                        Width="250"
                                        HorizontalAlignment="Right"
                                        Icon="{ui:SymbolIcon Search24}"
                                        PlaceholderText="Search skins..."
                                        Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                </Grid>

                                <ScrollViewer Grid.Row="1" Margin="10,0,10,10">
                                    <ItemsControl ItemsSource="{Binding FilteredSkins}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Width="200"
                                                    Margin="5"
                                                    ClipToBounds="True"
                                                    CornerRadius="12"
                                                    Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding
                                                            Command="{Binding DataContext.ToggleSkinSelectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            MouseAction="LeftClick" />
                                                    </Border.InputBindings>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#15FFFFFF" />
                                                            <Setter Property="BorderBrush" Value="#20FFFFFF" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#4CC3FF" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                </DataTrigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#25FFFFFF" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="120" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Image
                                                            Opacity="0.9"
                                                            Source="{Binding FullPreviewPath, TargetNullValue={x:Null}, FallbackValue={x:Null}}"
                                                            Stretch="UniformToFill" />

                                                        <StackPanel Grid.Row="1" Margin="12,10">
                                                            <ui:TextBlock
                                                                FontSize="14"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding Name}" />
                                                            <ui:TextBlock
                                                                FontTypography="Caption"
                                                                Opacity="0.6"
                                                                Text="XT VERSION" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border
                        Grid.Row="3"
                        Margin="0,20,0,0"
                        Background="#0AFFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid Margin="20">
                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    Margin="0,0,10,0"
                                    Appearance="Secondary"
                                    Command="{Binding SelectAllAvailableCommand}"
                                    Content="{Binding SelectAllText}">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="{Binding SelectAllIcon}" />
                                    </ui:Button.Icon>
                                </ui:Button>

                                <ui:Button
                                    Margin="0,0,10,0"
                                    Appearance="Danger"
                                    Command="{Binding ClearCacheCommand}"
                                    Content="Clear Cache"
                                    Icon="{ui:SymbolIcon Delete24}" />

                                <ui:Button
                                    Margin="0,0,10,0"
                                    Appearance="Primary"
                                    Command="{Binding RestoreCommand}"
                                    Content="Restore Originals"
                                    Icon="{ui:SymbolIcon ArrowUndo24}" />

                                <ui:Button
                                    Appearance="Success"
                                    Command="{Binding SwapCommand}"
                                    Content="APPLY SELECTED"
                                    FontWeight="Bold"
                                    Icon="{ui:SymbolIcon Flash24}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Padding="20,10" Header="BACKUP HISTORY">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,25">
                        <ui:TextBlock
                            FontSize="32"
                            FontTypography="Title"
                            FontWeight="Bold"
                            Text="Snapshot Backups" />
                        <ui:TextBlock Opacity="0.6" Text="View and restore previously applied texture snapshots." />
                    </StackPanel>

                    <ui:ListView
                        Grid.Row="1"
                        ItemsSource="{Binding SnapshotBackups}"
                        SelectedItem="{Binding SelectedBackup}">
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon
                                        Grid.Column="0"
                                        Margin="0,0,15,0"
                                        Symbol="History24" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <ui:TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding DisplayName}" />
                                        <ui:TextBlock
                                            FontTypography="Caption"
                                            Opacity="0.6"
                                            Text="{Binding CreationDate, StringFormat='{}Created on {0:MMMM dd, yyyy HH:mm}'}" />
                                    </StackPanel>
                                    <ui:Button
                                        Grid.Column="2"
                                        Appearance="Secondary"
                                        Command="{Binding DataContext.RestoreBackupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="RESTORE THIS" />
                                </Grid>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>

                    <ui:InfoBar
                        Title="Note"
                        Grid.Row="2"
                        Margin="0,20,0,0"
                        IsClosable="False"
                        IsOpen="True"
                        Message="Backups are automatically cleaned up based on your Max Retention settings."
                        Severity="Informational" />
                </Grid>
            </TabItem>
        </TabControl>

        <Grid
            x:Name="LoadingOverlay"
            Grid.RowSpan="2"
            Panel.ZIndex="10000"
            Background="#F0000000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="80"
                    Height="60"
                    IsIndeterminate="True" />
                <ui:TextBlock
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontTypography="Title"
                    Foreground="White"
                    Text="{Binding UpdateStatus}" />
            </StackPanel>
        </Grid>

        <ui:InfoBar
            x:Name="ToastInfoBar"
            Grid.Row="1"
            MaxWidth="350"
            Margin="0,20,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Panel.ZIndex="1000"
            IsClosable="True"
            IsOpen="False" />
    </Grid>
</ui:FluentWindow>
