<ui:FluentWindow
    x:Class="TextureSwapper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:TextureSwapper.Helpers"
    xmlns:local="clr-namespace:TextureSwapper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:TextureSwapper.Views"
    xmlns:vm="clr-namespace:TextureSwapper.ViewModels"
    Title="ProTanki Texture Swapper"
    Width="1250"
    Height="700"
    MinWidth="900"
    MinHeight="580"
    d:DataContext="{d:DesignInstance vm:MainViewModel,
                                     IsDesignTimeCreatable=False}"
    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources />

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UIScale}" ScaleY="{Binding UIScale}" />
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="PROTANKI TEXTURE SWAPPER"
            Height="46"
            VerticalAlignment="Center"
            FontWeight="Bold">
            <ui:TitleBar.Icon>
                <ui:ImageIcon
                    Width="40"
                    Margin="0,-10,0,-7"
                    Cursor="Hand"
                    MouseDown="OnLogoMouseDown"
                    Source="pack://application:,,,/Textures/logo.png" />
            </ui:TitleBar.Icon>

        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationView
                x:Name="RootNavigation"
                Grid.Column="0"
                IsBackButtonVisible="Collapsed"
                OpenPaneLength="250"
                PaneDisplayMode="Left">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem
                        Click="OnNavigationItemClick"
                        Content="Skins"
                        Icon="{ui:SymbolIcon Cube24}"
                        IsActive="True"
                        Tag="Skins" />
                    <ui:NavigationViewItem
                        Click="OnNavigationItemClick"
                        Content="Paints"
                        Icon="{ui:SymbolIcon PaintBrush24}"
                        Tag="Paints" />
                    <ui:NavigationViewItem
                        Click="OnNavigationItemClick"
                        Content="Backup History"
                        Icon="{ui:SymbolIcon History24}"
                        Tag="Backups" />
                    <ui:NavigationViewItem
                        Click="OnNavigationItemClick"
                        Content="Shot Effects"
                        Icon="{ui:SymbolIcon Flash24}"
                        Tag="ShotEffects" />
                </ui:NavigationView.MenuItems>
                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem
                        Click="OnAdminNavItemClick"
                        Content="Admin Panel"
                        Icon="{ui:SymbolIcon Key24}"
                        Tag="Admin" />
                    <ui:NavigationViewItem
                        Click="OnNavigationItemClick"
                        Content="Settings"
                        Icon="{ui:SymbolIcon Settings24}"
                        Tag="Settings" />
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>

            <Grid Grid.Column="1" Margin="20,10,20,20">
                <TabControl
                    x:Name="MainTabControl"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectedIndex="0">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </ControlTemplate>
                    </TabControl.Template>

                    <TabItem Header="SKINS">
                        <views:SkinsTabContent DataContext="{Binding SkinsTabVM}" />
                    </TabItem>

                    <TabItem Header="PAINTS">
                        <views:PaintsTabContent DataContext="{Binding PaintsTabVM}" />
                    </TabItem>

                    <TabItem Header="BACKUP HISTORY">
                        <views:BackupsTabContent DataContext="{Binding BackupsTabVM}" />
                    </TabItem>

                    <TabItem Header="SHOT EFFECTS">
                        <views:ShotEffectsTabContent DataContext="{Binding ShotEffectsTabVM}" />
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <views:AdminOverlayControl
            x:Name="AdminOverlay"
            Grid.RowSpan="2"
            Panel.ZIndex="9999"
            Visibility="Collapsed" />

        <Grid
            x:Name="LoadingOverlay"
            Grid.RowSpan="2"
            Panel.ZIndex="10000"
            Background="#E50B0B0B">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="80"
                    Height="60"
                    IsIndeterminate="True" />
                <ui:TextBlock
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontTypography="Title"
                    Foreground="White"
                    Text="{Binding UpdateStatus}" />
            </StackPanel>
        </Grid>

        <ui:InfoBar
            x:Name="ToastInfoBar"
            Grid.Row="1"
            MaxWidth="350"
            Margin="0,20,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Panel.ZIndex="1000"
            IsClosable="True"
            IsOpen="False" />
    </Grid>
</ui:FluentWindow>
