<ui:FluentWindow
    x:Class="TextureSwapper.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TextureSwapper.ViewModels"
    Title="Settings"
    Width="750"
    Height="650"
    d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UIScale}" ScaleY="{Binding UIScale}" />
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="SETTINGS" Grid.Row="0">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Settings24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20">
                <ui:TextBlock
                    Margin="0,0,0,10"
                    FontTypography="Subtitle"
                    Text="Backups" />
                <ui:Card Margin="0,0,0,20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <ui:TextBlock FontWeight="SemiBold" Text="Max Backup Retention" />
                                <ui:TextBlock
                                    FontTypography="Caption"
                                    Opacity="0.6"
                                    Text="Automatically delete backups older than these days" />
                            </StackPanel>
                            <ui:NumberBox
                                Grid.Column="1"
                                MinWidth="100"
                                Maximum="365"
                                Minimum="1"
                                Value="{Binding BackupRetentionDays, Mode=TwoWay}" />
                        </Grid>
                        <Slider
                            Margin="0,10,0,0"
                            IsSnapToTickEnabled="True"
                            Maximum="365"
                            Minimum="1"
                            TickFrequency="1"
                            Value="{Binding BackupRetentionDays, Mode=TwoWay}" />
                    </StackPanel>
                </ui:Card>

                <ui:TextBlock
                    Margin="0,15,0,10"
                    FontTypography="Subtitle"
                    Text="AI Texture Generator" />
                <ui:Card Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <ui:TextBlock FontWeight="SemiBold" Text="Hugging Face API Token" />
                                <ui:TextBlock
                                    FontTypography="Caption"
                                    Opacity="0.6"
                                    Text="Input your free Hugging Face token to enable the AI generator." />
                            </StackPanel>
                            <ui:Button
                                Grid.Column="1"
                                Appearance="Secondary"
                                Command="{Binding GetHuggingFaceTokenCommand}"
                                Content="Get Free Token"
                                Icon="{ui:SymbolIcon Open24}" />
                        </Grid>
                        <ui:TextBox
                            Margin="0,12,0,0"
                            PlaceholderText="Enter your API token here"
                            Text="{Binding HuggingFaceToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </ui:Card>

                <ui:TextBlock
                    Margin="0,15,0,10"
                    FontTypography="Subtitle"
                    Text="Appearance &amp; Display" />
                <ui:Card Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <ui:TextBlock FontWeight="SemiBold" Text="Application Theme" />
                                <ui:TextBlock
                                    FontTypography="Caption"
                                    Opacity="0.6"
                                    Text="Select the application's theme" />
                            </StackPanel>
                            <ComboBox
                                Grid.Column="1"
                                MinWidth="150"
                                ItemsSource="{Binding AvailableThemes}"
                                SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <ui:TextBlock FontWeight="SemiBold" Text="UI Scaling / Zoom" />
                                <ui:TextBlock
                                    FontTypography="Caption"
                                    Opacity="0.6"
                                    Text="Adjust the size of application interface elements" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Slider
                                    Width="120"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True"
                                    Maximum="1.3"
                                    Minimum="0.7"
                                    TickFrequency="0.05"
                                    Value="{Binding UIScale, Mode=TwoWay}" />
                                <ui:TextBlock
                                    Width="40"
                                    VerticalAlignment="Center"
                                    Text="{Binding UIScale, StringFormat={}{0:P0}}"
                                    TextAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:TextBlock
                    Margin="0,10,0,10"
                    FontTypography="Subtitle"
                    Text="Updates" />
                <ui:Card Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock FontWeight="SemiBold" Text="Software Updates" />
                            <ui:TextBlock
                                FontTypography="Caption"
                                Opacity="0.6"
                                Text="{Binding AppVersion, StringFormat='Currently installed: {0}'}" />
                        </StackPanel>
                        <ui:Button
                            Grid.Column="1"
                            Appearance="Primary"
                            Command="{Binding CheckForUpdatesCommand}"
                            Content="Check for Updates"
                            Icon="{ui:SymbolIcon ArrowSync24}" />
                    </Grid>
                </ui:Card>

                <ui:Card Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Opacity="0.6"
                                Symbol="Info24" />
                            <ui:TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="Status" />
                            <ui:ProgressRing
                                Grid.Column="2"
                                Width="20"
                                Height="20"
                                IsIndeterminate="True"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock
                                Grid.Column="0"
                                Opacity="0.6"
                                Text="Engine State:" />
                            <ui:TextBlock
                                Grid.Column="1"
                                FontWeight="SemiBold"
                                Text="{Binding UpdateStatus}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock
                                Grid.Column="0"
                                Opacity="0.6"
                                Text="Last Checked:" />
                            <ui:TextBlock Grid.Column="1" Text="{Binding LastCheckedTime}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:TextBlock
                    Margin="0,15,0,10"
                    FontTypography="Subtitle"
                    Text="Application Logs" />
                <ui:Card Margin="0,0,0,20" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="200" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:Button
                                Grid.Column="1"
                                Margin="0,0,10,0"
                                Command="{Binding OpenLogsFolderCommand}"
                                Content="Open Folder"
                                Icon="{ui:SymbolIcon Folder24}" />
                            <ui:Button
                                Grid.Column="2"
                                Command="{Binding RefreshLogsCommand}"
                                Content="Refresh"
                                Icon="{ui:SymbolIcon ArrowSync24}" />
                        </Grid>

                        <ScrollViewer
                            Grid.Row="0"
                            Height="200"
                            Padding="0,0,15,15"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                            <TextBox
                                AcceptsReturn="True"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Consolas, Courier New"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                IsReadOnly="True"
                                Text="{Binding LogContent, Mode=OneWay}"
                                TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </Grid>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <Grid
            x:Name="LoadingOverlay"
            Grid.RowSpan="2"
            Panel.ZIndex="10000"
            Background="#F0000000"
            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="60"
                    Height="40"
                    IsIndeterminate="True" />
                <ui:TextBlock
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    FontTypography="Subtitle"
                    Foreground="White"
                    Text="{Binding UpdateStatus}" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
