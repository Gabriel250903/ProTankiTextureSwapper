<ui:FluentWindow
    x:Class="TextureSwapper.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:TextureSwapper.ViewModels"
    Title="Settings"
    Width="700"
    Height="650"
    d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
    Background="#0F0F0F"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="SETTINGS" Grid.Row="0">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Settings24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20">
                <ui:TextBlock
                    Margin="0,0,0,10"
                    FontTypography="Subtitle"
                    Text="Appearance" />
                <ui:Card Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock FontWeight="SemiBold" Text="Application Theme" />
                            <ui:TextBlock
                                FontTypography="Caption"
                                Opacity="0.6"
                                Text="Switch between light and dark mode" />
                        </StackPanel>
                        <ui:Button
                            Grid.Column="1"
                            Command="{Binding ToggleThemeCommand}"
                            Content="Toggle Theme"
                            Icon="{ui:SymbolIcon WeatherMoon24}" />
                    </Grid>
                </ui:Card>

                <ui:TextBlock
                    Margin="0,10,0,10"
                    FontTypography="Subtitle"
                    Text="Backups" />
                <ui:Card Margin="0,0,0,20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <ui:TextBlock FontWeight="SemiBold" Text="Max Backup Retention" />
                                <ui:TextBlock
                                    FontTypography="Caption"
                                    Opacity="0.6"
                                    Text="Automatically delete backups older than these days" />
                            </StackPanel>
                            <ui:NumberBox
                                Grid.Column="1"
                                MinWidth="100"
                                Maximum="365"
                                Minimum="1"
                                Value="{Binding BackupRetentionDays, Mode=TwoWay}" />
                        </Grid>
                        <Slider
                            Margin="0,10,0,0"
                            IsSnapToTickEnabled="True"
                            Maximum="180"
                            Minimum="1"
                            TickFrequency="1"
                            Value="{Binding BackupRetentionDays, Mode=TwoWay}" />
                    </StackPanel>
                </ui:Card>

                <ui:TextBlock
                    Margin="0,10,0,10"
                    FontTypography="Subtitle"
                    Text="Updates" />
                <ui:Card Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock FontWeight="SemiBold" Text="Software Updates" />
                            <ui:TextBlock
                                FontTypography="Caption"
                                Opacity="0.6"
                                Text="{Binding AppVersion, StringFormat='Currently installed: {0}'}" />
                        </StackPanel>
                        <ui:Button
                            Grid.Column="1"
                            Appearance="Primary"
                            Command="{Binding CheckForUpdatesCommand}"
                            Content="Check for Updates"
                            Icon="{ui:SymbolIcon ArrowSync24}" />
                    </Grid>
                </ui:Card>

                <ui:Card Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Opacity="0.6"
                                Symbol="Info24" />
                            <ui:TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="Status" />
                            <ui:ProgressRing
                                Grid.Column="2"
                                Width="20"
                                Height="20"
                                IsIndeterminate="True"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock
                                Grid.Column="0"
                                Opacity="0.6"
                                Text="Engine State:" />
                            <ui:TextBlock
                                Grid.Column="1"
                                FontWeight="SemiBold"
                                Text="{Binding UpdateStatus}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock
                                Grid.Column="0"
                                Opacity="0.6"
                                Text="Last Checked:" />
                            <ui:TextBlock Grid.Column="1" Text="{Binding LastCheckedTime}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <Grid
            x:Name="LoadingOverlay"
            Grid.RowSpan="2"
            Panel.ZIndex="10000"
            Background="#F0000000"
            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="60"
                    Height="40"
                    IsIndeterminate="True" />
                <ui:TextBlock
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    FontTypography="Subtitle"
                    Foreground="White"
                    Text="{Binding UpdateStatus}" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
